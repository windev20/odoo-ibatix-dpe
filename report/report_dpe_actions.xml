<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_dpe" model="ir.actions.report">
        <field name="name">Rapport DPE</field>
        <field name="model">res.partner</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ibatix_dpe.report_dpe_document</field>
        <field name="report_file">ibatix_dpe.report_dpe_document</field>
        <field name="print_report_name">'DPE_' + (object.name or '').replace(' ', '_') + '_' + (object.dpe_numero or '') + '.pdf'</field>
        <field name="attachment">'DPE_' + (object.name or '').replace(' ','_') + '_' + (object.dpe_numero or '') + '.pdf'</field>
        <field name="attachment_use">True</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>
</odoo>
